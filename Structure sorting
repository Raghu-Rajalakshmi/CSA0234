#include<stdio.h>

struct student{
    int roll;
};

int main(){
    struct student s[3], temp;

    for(int i=0;i<3;i++)
        scanf("%d",&s[i].roll);

    for(int i=0;i<3;i++)
        for(int j=i+1;j<3;j++)
            if(s[i].roll > s[j].roll){
                temp = s[i];
                s[i] = s[j];
                s[j] = temp;
            }

    for(int i=0;i<3;i++)
        printf("%d ",s[i].roll);

    return 0;
}
