#include<stdio.h>

struct student{
    int roll;
    float marks;
};

int main(){
    struct student s[2];
    struct student *p = s;

    for(int i=0;i<2;i++){
        printf("Enter details:\n");
        scanf("%d %f",&(p+i)->roll,&(p+i)->marks);
    }

    for(int i=0;i<2;i++){
        printf("%d %.2f\n",(p+i)->roll,(p+i)->marks);
    }

    return 0;
}
