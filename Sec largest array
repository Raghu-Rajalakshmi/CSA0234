#include<stdio.h>
int main(){
    int arr[5]={1,5,3,9,7};
    int max=0,second=0;

    for(int i=0;i<5;i++){
        if(arr[i]>max){
            second=max;
            max=arr[i];
        }
        else if(arr[i]>second && arr[i]!=max)
            second=arr[i];
    }
    printf("Second = %d",second);
}
