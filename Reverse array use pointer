#include<stdio.h>

int main(){
    int n, i;
    int arr[100];

    printf("Enter size: ");
    scanf("%d", &n);

    printf("Enter elements:\n");
    for(i=0;i<n;i++)
        scanf("%d", &arr[i]);

    int *p = arr;

    printf("Reversed array:\n");
    for(i=n-1;i>=0;i--)
        printf("%d ", *(p+i));

    return 0;
}
