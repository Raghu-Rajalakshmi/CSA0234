#include<stdio.h>

int largest(int *a, int n){
    int i, max = *a;
    for(i=1;i<n;i++){
        if(*(a+i) > max)
            max = *(a+i);
    }
    return max;
}

int main(){
    int arr[100], n, i;

    printf("Enter size: ");
    scanf("%d",&n);

    printf("Enter elements:\n");
    for(i=0;i<n;i++)
        scanf("%d",&arr[i]);

    printf("Largest = %d", largest(arr,n));
    return 0;
}
